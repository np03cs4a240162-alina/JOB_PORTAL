# SmartJob Nepal — Environment Configuration Template
# Copy this file to '.env' and specify your actual credentials

# Database Configuration
DB_HOST=localhost
DB_NAME=jstack_db
DB_USER=root
DB_PASS=

# SMTP Configuration
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM_NAME="SmartJob Nepal"

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

